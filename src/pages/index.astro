---
import BlogCard from '@/components/BlogCard.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { getRecentPosts } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

const blog = await getRecentPosts(SITE.featuredPostCount)
const title = 'alein'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <section class="rounded-lg border hero-section">
    <!-- Mobile: Collapsible -->
    <details class="md:hidden">
      <summary
        class="flex cursor-pointer items-center justify-between px-4 py-3 hover:bg-muted/50 transition-colors"
      >
        <div class="flex items-center gap-3">
          <Icon name="lucide:scroll-text" class="size-5 text-muted-foreground" />
          <h3 class="text-lg font-medium">{title}</h3>
        </div>
        <Icon
          name="lucide:chevron-down"
          class="size-5 text-muted-foreground transition-transform duration-200 details-chevron"
        />
      </summary>
      <div class="hero-content px-6 pb-6 space-y-3"></div>
    </details>

    <!-- Desktop: Always expanded -->
    <div class="hidden md:block">
      <div class="flex flex-col space-y-1.5 p-6">
        <h3 class="text-3xl leading-none font-medium hero-title">{title}</h3>
      </div>
      <div class="hero-content p-6 pt-0 space-y-3"></div>
    </div>
  </section>

  <script>
    // DRY: Single source of truth for hero content
    const heroParagraphs = [
      'dev cloud chateado com a web moderna.',
      'uma vez sonhei com o fim do mundo e parecia agora.',
    ]

    // Render paragraphs with formatting
    const renderContent = () => {
      return heroParagraphs
        .map(
          (text) =>
            `<p class="text-muted-foreground text-sm">${text}</p>`
        )
        .join('')
    }

    // Inject content into both mobile and desktop versions
    const injectHeroContent = () => {
      document.querySelectorAll('.hero-content').forEach((el) => {
        el.innerHTML = renderContent()
      })
    }

    // Run on initial load and after every page navigation
    document.addEventListener('astro:page-load', injectHeroContent)
  </script>

  <style>
    details[open] .details-chevron {
      transform: rotate(180deg);
    }
  </style>
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">últimas cartas</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        revirar o engradado de garrafas<span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>
